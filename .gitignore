# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
src/*.egg-info/
dist/
*.egg
.eggs/

# Cython build artifacts (never commit these)
*.so
*.pyd
*.c
!src/riftcheck/**/__init__.py
wheelhouse/

# Python build artifacts under build/ (project docs in build/*.md stay tracked)
build/*
!build/*.md

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment variables
.env
.env.*

# PyPI API token for local `twine upload` (see pypi-token.example)
pypi-token
.pypi-token

# Riftcheck traces
.riftcheck/

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Claude Code local state (settings.local.json is intentionally tracked)
.claude/worktrees/

# Local ideation drafts (not part of the project)
archive-ideation/
